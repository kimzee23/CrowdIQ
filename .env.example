# =============================================================================
# CrowdIQ — Environment Variables Template
# Copy this file to .env and fill in the values
# =============================================================================

# --- App ---
APP_NAME="CrowdIQ"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:admin1234@localhost:5433/crowdiq_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Virtual Points ---
INITIAL_WALLET_BALANCE=1000

# --- Reputation Thresholds ---
REP_BRONZE=0
REP_SILVER=100
REP_GOLD=500
REP_PLATINUM=1500
REP_LEGEND=5000

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

#--- Mail config ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false

SMTP_FROM_NAME=CrowdIQ
SMTP_FROM_EMAIL=noreply@crowdiq.local

# --- OpenSearch (optional for future) ---
OPENSEARCH_URL=http://localhost:9200
