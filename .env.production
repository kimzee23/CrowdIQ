CORS_ORIGINS=["https://crowdiq.com","https://app.crowdiq.com"]

KEYCLOAK_SERVER_URL=https://auth.crowdiq.com
KEYCLOAK_REALM=crowdiq
KEYCLOAK_CLIENT_ID=crowdiq-api
KEYCLOAK_CLIENT_SECRET=********

#--- Email config ---
