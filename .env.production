SMTP_PORT=587
SMTP_USERNAME=********
SMTP_PASSWORD=********

SMTP_FROM_NAME=CrowdIQ
SMTP_FROM_EMAIL=noreply@crowdiq.com

OPENAI_API_KEY=********

